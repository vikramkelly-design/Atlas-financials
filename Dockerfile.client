FROM node:22-slim

WORKDIR /app

COPY package.json package-lock.json ./
COPY client/package.json client/
COPY server/package.json server/

RUN npm ci --workspace=finwise-client --include-workspace-root

COPY client/ client/

ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL

RUN npm run build --workspace=finwise-client

RUN npm install -g serve

EXPOSE 3000

CMD ["sh", "-c", "serve client/dist -s -l tcp://0.0.0.0:${PORT:-3000}"]
